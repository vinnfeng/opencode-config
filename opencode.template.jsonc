{
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "Anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Anthropic",
      "options": {
        "baseURL": "PROVIDER_URL/anthropic",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "ppio/pa/claude-opus-4-6": {
          "name": "Claude Opus 4.6 (strongest)",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "ppio/pa/claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "ppio/pa/claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5 (fast/cheap)",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        }
      }
    },
    "MiMoMifyLLM": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiMo mify llm.mioffice.cn",
      "options": {
        "baseURL": "PROVIDER_URL/v1",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "xiaomi/mimo-v2.5-pro": {
          "name": "MiMo V2.5 Pro (mify internal new entry)",
          "limit": {
            "context": 1000000,
            "output": 131072
          }
        },
        "xiaomi/mimo-v2.5": {
          "name": "MiMo V2.5 (mify internal new entry)",
          "limit": {
            "context": 1000000,
            "output": 131072
          }
        },
        "xiaomi/mimo-v2-pro": {
          "name": "MiMo V2 Pro (mify internal new entry)",
          "limit": {
            "context": 1000000,
            "output": 131072
          }
        },
        "xiaomi/mimo-v2-omni": {
          "name": "MiMo V2 Omni (mify internal new entry)",
          "limit": {
            "context": 256000,
            "output": 131072
          }
        }
      }
    },
    "Zhipu": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Zhipu",
      "options": {
        "baseURL": "PROVIDER_URL/v1/",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "zhipuai/glm-5": {
          "name": "GLM-5",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "zhipuai/glm-4.7": {
          "name": "GLM-4.7",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "zhipuai/glm-4.6": {
          "name": "GLM-4.6",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "zhipuai/glm-5.1": {
          "name": "GLM-5.1 (744B open-source, agent-best)",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "zhipuai/glm-5-turbo": {
          "name": "GLM-5 Turbo (agent-optimized)",
          "limit": {
            "context": 200000,
            "output": 128000
          }
        }
      }
    },
    "OpenAI": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI",
      "options": {
        "baseURL": "PROVIDER_URL/v1/",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
