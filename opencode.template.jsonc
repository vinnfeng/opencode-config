{
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "Anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Anthropic",
      "options": {
        "baseURL": "PROVIDER_URL/anthropic",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "ppio/pa/claude-opus-4-6": {
          "name": "Claude Opus 4.6 (strongest)",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "ppio/pa/claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "ppio/pa/claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5 (fast/cheap)",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        }
      }
    },
    "Zhipu": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Zhipu",
      "options": {
        "baseURL": "PROVIDER_URL/v1/",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "zhipuai/glm-5": {
          "name": "zhipuai/glm-5",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    },
    "OpenAI": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI",
      "options": {
        "baseURL": "PROVIDER_URL/v1/",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "azure_openai/gpt-5.4-pro": {
          "name": "gpt-5.4-pro",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "azure_openai/gpt-5.4": {
          "name": "gpt-5.4",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        }
      }
    },
    "Google": {
      "npm": "@ai-sdk/google",
      "options": {
        "baseURL": "PROVIDER_GOOGLE_URL/gemini",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "gemini-3.1-pro-preview": {
          "name": "gemini-3.1-pro-preview",
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        },
        "gemini-3-flash-preview": {
          "name": "gemini-3-flash-preview",
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  }
}
