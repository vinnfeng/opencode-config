{
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "Anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Anthropic",
      "options": {
        "baseURL": "PROVIDER_URL/anthropic",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "ppio/pa/claude-opus-4-6": {
          "name": "Claude Opus 4.6 (strongest)",
          "limit": { "context": 200000, "output": 65536 }
        },
        "ppio/pa/claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "limit": { "context": 200000, "output": 65536 }
        },
        "ppio/pa/claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5 (fast/cheap)",
          "limit": { "context": 200000, "output": 65536 }
        }
      }
    },
    "Zhipu": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Zhipu",
      "options": {
        "baseURL": "PROVIDER_URL/v1/",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "zhipuai/glm-5": {
          "name": "GLM-5",
          "limit": { "context": 128000, "output": 16384 }
        }
      }
    },
    "OpenAI": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI",
      "options": {
        "baseURL": "PROVIDER_URL/v1/",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "azure_openai/gpt-5.4-pro": {
          "name": "GPT-5.4 Pro",
          "limit": { "context": 200000, "output": 65536 }
        },
        "azure_openai/gpt-5.4": {
          "name": "GPT-5.4",
          "limit": { "context": 200000, "output": 65536 }
        },
        "azure_openai/o4-mini": { "name": "O4 Mini" },
        "azure_openai/o3": { "name": "O3" }
      }
    },
    "Google": {
      "npm": "@ai-sdk/google",
      "options": {
        "baseURL": "PROVIDER_GOOGLE_URL/gemini",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro",
          "limit": { "context": 1000000, "output": 65536 }
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash",
          "limit": { "context": 1000000, "output": 65536 }
        },
        "gemini-2.5-pro": { "name": "Gemini 2.5 Pro" }
      }
    },
    "DeepSeek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "PROVIDER_URL/v1/",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "ppio/DeepseekV3.2": { "name": "DeepSeek V3.2" },
        "ppio/deepseek-r1-0528": { "name": "DeepSeek R1" }
      }
    },
    "Kimi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kimi",
      "options": {
        "baseURL": "PROVIDER_URL/v1/",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "tongyi/kimi-k2.5": { "name": "Kimi K2.5" }
      }
    },
    "bailian": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "bailian",
      "options": {
        "baseURL": "https://coding.dashscope.aliyuncs.com/v1",
        "apiKey": "BAILIAN_API_KEY"
      },
      "models": {
        "qwen3.5-plus": { "id": "qwen3.5-plus", "name": "qwen3.5-plus" },
        "glm-5": { "id": "glm-5", "name": "glm-5" }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  }
}
