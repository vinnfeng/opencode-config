    "bailian": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "bailian",
      "options": {
        "baseURL": "https://coding.dashscope.aliyuncs.com/v1",
        "apiKey": "BAILIAN_API_KEY"
      },
      "models": {
        "qwen3.5-plus": {
          "id": "qwen3.5-plus",
          "name": "qwen3.5-plus",
          "limit": {
