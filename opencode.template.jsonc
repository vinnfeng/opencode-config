        },
        "azure_openai/gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "azure_openai/gpt-5-nano": {
          "name": "GPT-5 Nano",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "azure_openai/gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "azure_openai/gpt-5.2-codex": {
          "name": "GPT-5.2 Codex",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "azure_openai/o4-mini": {
