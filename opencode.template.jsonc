    "Mify-Kimi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kimi",
      "options": {
        "baseURL": "PROVIDER_URL/v1/",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "tongyi/kimi-k2.5": {
          "name": "Kimi K2.5",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "tongyi/kimi-k2-thinking": {
          "name": "Kimi K2 Thinking (1T MoE, 300+ tool calls)",
          "limit": {
            "context": 256000,
            "output": 65536
          }
        }
      }
    },
    "bailian": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "bailian",
      "options": {
        "baseURL": "https://coding.dashscope.aliyuncs.com/v1",
        "apiKey": "BAILIAN_API_KEY"
      },
      "models": {
        "qwen3.5-plus": {
          "id": "qwen3.5-plus",
          "name": "qwen3.5-plus",
          "limit": {
            "context": 131072,
            "output": 16384
          }
        },
        "glm-5": {
          "id": "glm-5",
          "name": "glm-5",
          "limit": {
            "context": 131072,
            "output": 16384
