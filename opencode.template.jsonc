{
  "plugin": [
    "oh-my-opencode@latest"
  ],
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "Mify-Anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Mify-Anthropic",
      "options": {
        "baseURL": "MIFY_URL/anthropic",
        "apiKey": "MIFY_API_KEY"
      },
      "models": {
        "ppio/pa/claude-opus-4-6": {
          "name": "Claude Opus 4.6 (strongest)",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "ppio/pa/claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "ppio/pa/claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5 (fast/cheap)",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        }
      }
    },
    "Mify-Zhipu": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mify-Zhipu",
      "options": {
        "baseURL": "MIFY_URL/v1/",
        "apiKey": "MIFY_API_KEY"
      },
      "models": {
        "zhipuai/glm-5": {
          "name": "GLM-5",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "zhipuai/glm-4.7": {
          "name": "GLM-4.7",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "zhipuai/glm-4.6": {
          "name": "GLM-4.6",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    },
    "Mify-OpenAI": {
      "npm": "@ai-sdk/openai",
      "name": "Mify-OpenAI",
      "options": {
        "baseURL": "MIFY_URL/v1/",
        "apiKey": "MIFY_API_KEY"
      },
      "models": {
        "azure_openai/gpt-5.4-pro": {
          "name": "GPT-5.4 Pro",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "azure_openai/gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "azure_openai/gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "azure_openai/gpt-5.2-codex": {
          "name": "GPT-5.2 Codex",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "azure_openai/o4-mini": {
          "name": "O4 Mini",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "azure_openai/o3": {
          "name": "O3",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        }
      }
    },
    "Mify-Google": {
      "npm": "@ai-sdk/google",
      "options": {
        "baseURL": "MIFY_GOOGLE_URL/gemini",
        "apiKey": "MIFY_API_KEY"
      },
      "models": {
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro",
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash",
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        }
      }
    },
    "Mify-DeepSeek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mify-DeepSeek",
      "options": {
        "baseURL": "MIFY_URL/v1/",
        "apiKey": "MIFY_API_KEY"
      },
      "models": {
        "ppio/DeepseekV3.2": {
          "name": "DeepSeek V3.2",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "ppio/deepseek-r1-0528": {
          "name": "DeepSeek R1",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    },
    "Mify-Kimi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mify-Kimi",
      "options": {
        "baseURL": "MIFY_URL/v1/",
        "apiKey": "MIFY_API_KEY"
      },
      "models": {
        "tongyi/kimi-k2.5": {
          "name": "Kimi K2.5",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    },
    "bailian": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "bailian",
      "options": {
        "baseURL": "https://coding.dashscope.aliyuncs.com/v1",
        "apiKey": "BAILIAN_API_KEY"
      },
      "models": {
        "qwen3.5-plus": {
          "id": "qwen3.5-plus",
          "name": "qwen3.5-plus",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "glm-5": {
          "id": "glm-5",
          "name": "glm-5",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  }
}
