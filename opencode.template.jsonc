        },
        "qwen3.6-plus": {
          "id": "qwen3.6-plus",
          "name": "qwen3.6-plus (latest)",
          "limit": {
            "context": 131072,
            "output": 16384
          }
        }
      }
    },
    "Mify-xAI": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "xAI",
      "options": {
        "baseURL": "PROVIDER_URL/v1/",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "ppio/grok-4": {
          "name": "Grok-4 (256K, deep reasoning)",
