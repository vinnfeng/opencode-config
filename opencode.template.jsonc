    },
    "Mify-DeepSeek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "PROVIDER_URL/v1/",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "ppio/DeepseekV3.2": {
          "name": "DeepSeek V3.2",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "ppio/deepseek-r1-0528": {
          "name": "DeepSeek R1",
          "limit": {
            "context": 131072,
            "output": 65536
