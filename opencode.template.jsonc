          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "azure_openai/o3": {
          "name": "O3",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "azure_openai/gpt-oss-120b": {
          "name": "GPT-OSS-120B (open-weight, single-GPU)",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        }
      }
    },
    "Mify-Google": {
      "npm": "@ai-sdk/google",
      "options": {
        "baseURL": "PROVIDER_GOOGLE_URL/gemini",
        "apiKey": "PROVIDER_API_KEY"
      },
      "models": {
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro",
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        },
        "gemini-3.5-flash": {
          "name": "Gemini 3.5 Flash (frontier benchmark superior to 3.1-pro on agentic/coding/multimodal; reasoning enabled)",
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        }
