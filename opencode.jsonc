{
  "plugin": [
    "oh-my-opencode@latest"
  ],
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "Mify-Anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Mify-Anthropic",
      "options": {
        "baseURL": "http://model.mify.ai.srv/anthropic",
        "apiKey": "sk-0AaWLIyvTS503aV452CUqu86ZNuxWXOTSlemATHfywPd51CK"
      },
      "models": {
        "ppio/pa/claude-opus-4-6": {
          "name": "Claude Opus 4.6 (strongest)",
          "limit": { "context": 200000, "output": 65536 }
        },
        "ppio/pa/claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "limit": { "context": 200000, "output": 65536 }
        },
        "ppio/pa/claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5 (fast/cheap)",
          "limit": { "context": 200000, "output": 65536 }
        }
      }
    },
    "Mify-Zhipu": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mify-Zhipu",
      "options": {
        "baseURL": "http://model.mify.ai.srv/v1/",
        "apiKey": "sk-0AaWLIyvTS503aV452CUqu86ZNuxWXOTSlemATHfywPd51CK"
      },
      "models": {
        "zhipuai/glm-5": { "name": "zhipuai/glm-5" }
