{
  "plugin": ["oh-my-opencode@latest"],
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "opencode",
      "options": {
        "baseURL": "https://api.opencode.ai/v1",
        "apiKey": ""
      },
      "models": {
        "trinity-large-preview-free": {
          "name": "trinity-large-preview-free",
          "limit": {"context": 200000, "output": 64000}
        },
        "gpt-5-nano": {
          "name": "gpt-5-nano",
          "limit": {"context": 128000, "output": 32000}
        },
        "gpt-5-mini": {
          "name": "gpt-5-mini",
          "limit": {"context": 128000, "output": 32000}
        }
      }
    },
    "bailian": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "bailian",
      "options": {
        "baseURL": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "apiKey": "sk-sp-ae03e7f782c7427cbdb4bda0d6d0a5de"
      },
      "models": {
        "qwen3.5-plus": {
          "name": "qwen3.5-plus",
          "limit": {"context": 256000, "output": 64000}
        },
        "qwen3.5-turbo": {
          "name": "qwen3.5-turbo",
          "limit": {"context": 256000, "output": 64000}
        }
      }
    },
    "Mify-Zhipu": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mify-Zhipu",
      "options": {
        "baseURL": "http://model.mify.ai.srv/v1/",
        "apiKey": "sk-0AaWLIyvTS503aV452CUqu86ZNuxWXOTSlemATHfywPd51CK"
      },
      "models": {
        "zhipuai/glm-4.7": {"name": "zhipuai/glm-4.7"}
      }
    },
    "Mify-OpenAI": {
      "npm": "@ai-sdk/openai",
      "name": "Mify-OpenAI",
      "options": {
        "baseURL": "http://model.mify.ai.srv/v1/",
        "apiKey": "sk-0AaWLIyvTS503aV452CUqu86ZNuxWXOTSlemATHfywPd51CK"
      },
      "models": {
        "azure_openai/gpt-5.2-codex": {"name": "gpt-5.2-codex"},
        "azure_openai/gpt-5.1-codex": {"name": "gpt-5.1-codex"},
        "azure_openai/gpt-5.4-pro": {"name": "gpt-5.4-pro"},
        "azure_openai/gpt-5.3-codex": {"name": "gpt-5.3-codex"},
        "azure_openai/gpt-5.2-chat": {"name": "gpt-5.2-chat"}
      }
    },
    "Mify-Xiaomi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mify-Xiaomi",
      "options": {
        "baseURL": "http://model.mify.ai.srv/v1/",
        "apiKey": "sk-0AaWLIyvTS503aV452CUqu86ZNuxWXOTSlemATHfywPd51CK"
      },
      "models": {
        "xiaomi/mimo-v2-flash": {"name": "xiaomi/mimo-v2-flash"},
        "xiaomi/mimo-v2-pro": {"name": "mimo-v2-pro"},
        "xiaomi/mimo-v2-omni": {"name": "mimo-v2-omni"},
        "xiaomi/mimo-claw-latest": {"name": "mimo-claw-latest"}
      }
    },
    "Mify-Kimi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mify-Kimi",
      "options": {
        "baseURL": "http://model.mify.ai.srv/v1/",
        "apiKey": "sk-0AaWLIyvTS503aV452CUqu86ZNuxWXOTSlemATHfywPd51CK"
      },
      "models": {
        "volcengine_maas/kimi-k2-250711": {"name": "volcengine_maas/kimi-k2-250711"},
        "Pro/moonshotai/Kimi-K2.5": {
          "name": "Kimi-K2.5",
          "headers": {"X-Model-Provider-Id": "siliconflow"},
          "limit": {"context": 260000, "output": 128000}
        }
      }
    },
    "Mify-Google": {
      "npm": "@ai-sdk/google",
      "name": "Mify-Google",
      "options": {
        "baseURL": "http://model-sgp.mify.ai.srv/gemini",
        "apiKey": "sk-0AaWLIyvTS503aV452CUqu86ZNuxWXOTSlemATHfywPd51CK"
      },
      "models": {
        "gemini-3-pro-preview-pt": {"name": "gemini-3-pro", "limit": {"context": 1000000, "output": 128000}},
        "gemini-3-flash-preview": {"name": "gemini-3-flash", "limit": {"context": 1000000, "output": 128000}}
      }
    }
  }
}
