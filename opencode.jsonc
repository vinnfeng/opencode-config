{
  "plugin": [
    "oh-my-opencode@latest"
  ],
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "Mify-Zhipu": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mify-Zhipu",
      "options": {
        "baseURL": "http://model.mify.ai.srv/v1/",
        "apiKey": "sk-KoVyIWzWkTa7MP4nDR5cu0JquLiwN5xVybihIg5PH3lt638e"
      },
      "models": {
        "zhipuai/glm-4.7": {
          "name": "zhipuai/glm-4.7"
        }
      }
    },
    "Mify-OpenAI": {
      "npm": "@ai-sdk/openai",
      "name": "Mify-OpenAI",
      "options": {
        "baseURL": "http://model.mify.ai.srv/v1/",
        "apiKey": "sk-KoVyIWzWkTa7MP4nDR5cu0JquLiwN5xVybihIg5PH3lt638e"
      },
      "models": {
        "azure_openai/gpt-5.2-codex": {
          "name": "gpt-5.2-codex"
        },
        "azure_openai/gpt-5.1-codex": {
          "name": "gpt-5.1-codex"
        },
        "azure_openai/gpt-5.4-pro": {
          "name": "gpt-5.4-pro"
        },
        "azure_openai/gpt-5.3-codex": {
          "name": "gpt-5.3-codex"
        },
        "azure_openai/gpt-5.2-chat": {
          "name": "gpt-5.2-chat"
        }
      }
    },
    "Mify-Xiaomi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mify-Xiaomi",
      "options": {
        "baseURL": "http://model.mify.ai.srv/v1/",
        "apiKey": "sk-KoVyIWzWkTa7MP4nDR5cu0JquLiwN5xVybihIg5PH3lt638e"
      },
      "models": {
        "xiaomi/mimo-v2-flash": {
          "name": "xiaomi/mimo-v2-flash"
        },
        "xiaomi/mimo-v2-pro": {
          "name": "mimo-v2-pro"
        },
        "xiaomi/mimo-v2-omni": {
          "name": "mimo-v2-omni"
        },
        "xiaomi/mimo-claw-latest": {
          "name": "mimo-claw-latest"
        },
        "xiaomi/mimo-claw-0307-rl": {
          "name": "mimo-claw-0307-rl"
        },
        "xiaomi/MiMo-VL-7B-RL": {
          "name": "MiMo-VL-7B-RL"
        },
        "xiaomi/MiMo-VL-7B-RL-0808": {
          "name": "MiMo-VL-7B-RL-0808"
        },
        "xiaomi/Mi-BRAG-VL": {
          "name": "Mi-BRAG-VL"
        }
      }
    },
    "Mify-Kimi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mify-Kimi",
      "options": {
        "baseURL": "http://model.mify.ai.srv/v1/",
        "apiKey": "sk-KoVyIWzWkTa7MP4nDR5cu0JquLiwN5xVybihIg5PH3lt638e"
      },
      "models": {
        "volcengine_maas/kimi-k2-250711": {
          "name": "volcengine_maas/kimi-k2-250711"
        },
        "Pro/moonshotai/Kimi-K2.5": {
          "name": "Kimi-K2.5",
          "headers": {
            "X-Model-Provider-Id": "siliconflow"
          },
          "limit": {
            "context": 260000,
            "output": 128000
          },
          "variants": {
            "thinking": {
              "enable_thinking": false
            }
          }
        }
      }
    },
    "Mify-Google": {
      "npm": "@ai-sdk/google",
      "options": {
        "baseURL": "http://model-sgp.mify.ai.srv/gemini",
        "apiKey": "sk-KoVyIWzWkTa7MP4nDR5cu0JquLiwN5xVybihIg5PH3lt638e"
      },
      "models": {
        "gemini-3-pro-preview-pt": {
          "name": "gemini-3-pro",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "gemini-3-flash-preview": {
          "name": "gemini-3-flash",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        }
      }
    }
  }
}