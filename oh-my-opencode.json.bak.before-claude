{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  
  "_version": "2.0-2026-02-28",
  "_upgrade_note": "移植自 OpenClaw v2026.2.28（适配版）",
  "_changes": [
    "新增配额监控机制（避免配额耗尽）",
    "新增健康检查（项目级）",
    "升级记忆系统（支持语义搜索）",
    "优化升级管理（自动化）",
    "完善教训记录机制"
  ],
  
  "agents": {
    "ceo": {
      "name": "CEO",
      "model": "Mify-OpenAI/azure_openai/gpt-5.3-codex",
      "prompt": "You are the CEO of this AI engineering system. Analyze tasks, recommend which agent should handle them, and coordinate multi-agent workflows.",
      "tools": ["all"]
    },
    "architect": {
      "name": "Architect",
      "model": "Mify-OpenAI/azure_openai/gpt-5.3-codex",
      "prompt": "You are the architect. Design solutions, define API boundaries, concurrency model, lifecycle.",
      "tools": ["read", "write", "search", "web"]
    },
    "coder": {
      "name": "Coder",
      "model": "Mify-OpenAI/azure_openai/gpt-5.3-codex",
      "prompt": "You are the coder with FULL EXECUTION RIGHTS. Implement code, run tests, fix bugs.",
      "tools": ["read", "write", "terminal", "git"]
    },
    "reviewer": {
      "name": "Reviewer",
      "model": "Mify-Xiaomi/xiaomi/mimo-v2-flash",
      "prompt": "You are the reviewer. Review code for security, performance, and quality.",
      "tools": ["read", "search", "web"]
    },
    "researcher": {
      "name": "Researcher",
      "model": "Mify-Google/gemini-3-flash-preview",
      "prompt": "You are the researcher. Scan technologies and best practices.",
      "tools": ["search", "web"]
    }
  },
  
  "categories": {
    "visual-engineering": { "model": "Mify-Google/gemini-3-pro-preview-pt" },
    "ultrabrain": { "model": "Mify-Google/gemini-3-pro-preview-pt" },
    "deep": { "model": "Mify-Google/gemini-3-pro-preview-pt" },
    "artistry": { "model": "Mify-Google/gemini-3-pro-preview-pt" },
    "quick": { "model": "Mify-Google/gemini-3-flash-preview" },
    "unspecified-low": { "model": "Mify-Google/gemini-3-flash-preview" },
    "unspecified-high": { "model": "Mify-Google/gemini-3-pro-preview-pt" },
    "writing": { "model": "Mify-Google/gemini-3-pro-preview-pt" }
  },
  
  "background_task": {
    "defaultConcurrency": 2
  },
  
  "skills": {
    "enabled": true
  },
  
  "memory": {
    "enabled": true,
    "maxContext": 10
  },
  
  "_quota_monitoring": {
    "enabled": true,
    "checkInterval": "1h",
    "thresholds": {
      "warning": 70,
      "critical": 90
    },
    "fallbackModels": {
      "openai/gpt-5.3-codex": "opencode/gpt-5-nano",
      "anthropic/claude-sonnet-4-6": "opencode/gpt-5-nano",
      "google-antigravity/gemini-3-flash": "opencode/gpt-5-nano"
    }
  },
  
  "_health_check": {
    "enabled": true,
    "checkInterval": "6h",
    "items": [
      "OpenCode version",
      "oh-my-opencode version",
      "model availability",
      "memory directory writable",
      "agent configs valid"
    ]
  }
}
