{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "_comment": "公司 OpenCode 全局通用 category 基线 v0.3 | 2026-06-10 | 仅保留跨伙伴默认模型档位；项目特化策略下沉到各项目 .opencode/oh-my-openagent.json[c]",
  "categories": {
    "ultrabrain": {
      "_comment": "通用高难度推理、复杂调试、架构决策；默认走降本 ppio GPT-5.5，Opus/Azure 仅作保留兜底",
      "model": "Mify-OpenAI/ppio/pa/gpt-5.5",
      "fallback_models": [
        "Mify-Anthropic/ppio/pa/claude-opus-4-8",
        "Mify-Anthropic/ppio/pa/claude-opus-4-7",
        "Mify-OpenAI/azure_openai/gpt-5.5",
        "Mify-OpenAI/azure_openai/gpt-5.4",
        "Mify-Anthropic/ppio/pa/claude-sonnet-4-6"
      ]
    },
    "deep": {
      "_comment": "通用深度调研、自主 end-to-end 长任务；默认走降本 ppio GPT-5.5，Claude/Azure 作兜底",
      "model": "Mify-OpenAI/ppio/pa/gpt-5.5",
      "fallback_models": [
        "Mify-Anthropic/ppio/pa/claude-opus-4-8",
        "Mify-Anthropic/ppio/pa/claude-opus-4-7",
        "Mify-Anthropic/ppio/pa/claude-sonnet-4-6",
        "Mify-OpenAI/azure_openai/gpt-5.5",
        "Mify-OpenAI/azure_openai/gpt-5.4"
      ]
    },
    "visual-engineering": {
      "_comment": "通用前端/UI/多模态任务；公司 mify Gemini native 暂不支持 3.5-flash，主选 3.1-pro，Sonnet 兜底",
      "model": "Mify-Google/gemini-3.1-pro-preview",
      "fallback_models": [
        "Mify-Anthropic/ppio/pa/claude-sonnet-4-6"
      ]
    },
    "quick": {
      "_comment": "通用轻量任务、单文件改动、typo fix、简单 config 修改；轻量快速，不占用 Opus",
      "model": "Mify-Xiaomi/xiaomi/mimo-v2-flash",
      "fallback_models": [
        "Mify-Anthropic/ppio/pa/claude-haiku-4-5-20251001",
        "Mify-OpenAI/azure_openai/gpt-5-nano",
        "Mify-Anthropic/ppio/pa/claude-haiku-4-5"
      ]
    },
    "writing": {
      "_comment": "通用中文技术写作、文档、报告；Sonnet 主力，GLM/Kimi 兜底",
      "model": "Mify-OpenAI/ppio/pa/gpt-5.5",
      "fallback_models": [
        "Mify-Anthropic/ppio/pa/claude-sonnet-4-6",
        "Mify-Zhipu/zhipuai/glm-5",
        "Mify-Kimi/tongyi/kimi-k2.5"
      ]
    },
    "unspecified-high": {
      "_comment": "通用分类不明的高难度任务；Sonnet 主力，Opus/GPT 备用",
      "model": "Mify-OpenAI/ppio/pa/gpt-5.5",
      "fallback_models": [
        "Mify-Anthropic/ppio/pa/claude-sonnet-4-6",
        "Mify-Anthropic/ppio/pa/claude-opus-4-8",
        "Mify-Anthropic/ppio/pa/claude-opus-4-7",
        "Mify-OpenAI/azure_openai/gpt-5.5",
        "Mify-OpenAI/azure_openai/gpt-5.4"
      ]
    },
    "unspecified-low": {
      "_comment": "通用分类不明的低难度任务；Haiku 快速，DeepSeek/GPT nano 备用",
      "model": "Mify-Xiaomi/xiaomi/mimo-v2-flash",
      "fallback_models": [
        "Mify-Anthropic/ppio/pa/claude-haiku-4-5-20251001",
        "Mify-Xiaomi/xiaomi/deepseek-v3.1",
        "Mify-OpenAI/azure_openai/gpt-5-nano"
      ]
    }
  },
  "background_task": {
    "defaultConcurrency": 3
  },
  "experimental": {
    "preemptive_compaction": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 3
      },
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        }
      }
    }
  }
}
