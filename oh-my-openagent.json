{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "_comment": "OpenCode home routing v0.4 | 2026-06-10 | 降本同步：PPIO GPT5.5/MiMo 为主，Claude 因 RPM 限流仅作 fallback/reserve，不是删除或禁用",
  "categories": {
    "ultrabrain": {
      "_comment": "架构决策、复杂多系统调试、算法设计：默认走 PPIO GPT5.5/Azure GPT5.5；Claude 限流后保留为强兜底",
      "model": "Mify-OpenAI/ppio/pa/gpt-5.5",
      "fallback_models": [
        "Mify-OpenAI/azure_openai/gpt-5.5",
        "Mify-OpenAI/azure_openai/gpt-5.4",
        "Mify-Anthropic/ppio/pa/claude-opus-4-8",
        "Mify-Anthropic/ppio/pa/claude-opus-4-7",
        "Mify-Anthropic/ppio/pa/claude-sonnet-4-6",
        "Mify-Xiaomi/xiaomi/mimo-v2.5-pro",
        "Xiaomi/mimo-v2.5-pro"
      ]
    },
    "deep": {
      "_comment": "调研报告、自主 end-to-end 长任务：默认走 PPIO GPT5.5；Claude 作为限流后的保底通道",
      "model": "Mify-OpenAI/ppio/pa/gpt-5.5",
      "fallback_models": [
        "Mify-OpenAI/azure_openai/gpt-5.5",
        "Mify-OpenAI/azure_openai/gpt-5.4",
        "Mify-Anthropic/ppio/pa/claude-opus-4-8",
        "Mify-Anthropic/ppio/pa/claude-opus-4-7",
        "Mify-Anthropic/ppio/pa/claude-sonnet-4-6",
        "Mify-Xiaomi/xiaomi/mimo-v2.5-pro",
        "Xiaomi/mimo-v2.5-pro"
      ]
    },
    "visual-engineering": {
      "_comment": "mify Gemini native 不支持 gemini-3.5-flash（5/29 公司侧实证 400）；visual 主选使用 3.1-pro，Sonnet 兜底",
      "model": "Mify-Google/gemini-3.1-pro-preview",
      "fallback_models": [
        "Mify-Anthropic/ppio/pa/claude-sonnet-4-6"
      ]
    },
    "quick": {
      "model": "Xiaomi/mimo-v2-flash",
      "fallback_models": [
        "Mify-OpenAI/azure_openai/o4-mini",
        "Xiaomi/mimo-v2.5",
        "Mify-Anthropic/ppio/pa/claude-haiku-4-5-20251001"
      ]
    },
    "writing": {
      "model": "Mify-Kimi/tongyi/kimi-k2.5",
      "fallback_models": [
        "Mify-OpenAI/ppio/pa/gpt-5.5",
        "Mify-Anthropic/ppio/pa/claude-sonnet-4-6",
        "Mify-Zhipu/zhipuai/glm-5",
        "Mify-Xiaomi/xiaomi/mimo-v2.5-pro"
      ]
    },
    "unspecified-high": {
      "model": "Mify-OpenAI/ppio/pa/gpt-5.5",
      "fallback_models": [
        "Mify-OpenAI/azure_openai/gpt-5.5",
        "Mify-Anthropic/ppio/pa/claude-opus-4-8",
        "Mify-Anthropic/ppio/pa/claude-opus-4-7",
        "Mify-OpenAI/azure_openai/gpt-5.4",
        "Mify-Xiaomi/xiaomi/mimo-v2.5-pro",
        "Xiaomi/mimo-v2.5-pro"
      ]
    },
    "unspecified-low": {
      "model": "Mify-Xiaomi/xiaomi/mimo-v2.5",
      "fallback_models": [
        "Xiaomi/mimo-v2.5",
        "Xiaomi/mimo-v2-flash",
        "Mify-Anthropic/ppio/pa/claude-haiku-4-5-20251001"
      ]
    }
  },
  "background_task": {
    "defaultConcurrency": 3
  },
  "experimental": {
    "preemptive_compaction": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 3
      },
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        }
      }
    }
  }
}
