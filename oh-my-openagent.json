{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "_comment": "OpenCode home routing v0.3 | 2026-05-29 | active fallback 清百炼；保留 Mify/MiMo/PPIO 最小可行链",
  "categories": {
    "ultrabrain": {
      "_comment": "架构决策、复杂多系统调试、算法设计：先用最强 Claude，再试 GPT，再降到 Sonnet/MiMo",
      "model": "Anthropic/ppio/pa/claude-opus-4-7",
      "fallback_models": ["OpenAI/azure_openai/gpt-5.5", "OpenAI/azure_openai/gpt-5.4", "Anthropic/ppio/pa/claude-sonnet-4-6", "Mify-Xiaomi/xiaomi/mimo-v2.5-pro", "Xiaomi/mimo-v2.5-pro"]
    },
    "deep": {
      "_comment": "调研报告、自主 end-to-end 长任务：强推理+长上下文，有限 fallback 快速收敛",
      "model": "Anthropic/ppio/pa/claude-opus-4-7",
      "fallback_models": ["Anthropic/ppio/pa/claude-sonnet-4-6", "OpenAI/azure_openai/gpt-5.5", "OpenAI/azure_openai/gpt-5.4", "Mify-Xiaomi/xiaomi/mimo-v2.5-pro", "Xiaomi/mimo-v2.5-pro"]
    },
    "visual-engineering": {
      "model": "Google/gemini-3.5-flash",
      "fallback_models": ["Google/gemini-3.1-pro-preview", "Anthropic/ppio/pa/claude-sonnet-4-6"]
    },
    "quick": {
      "model": "Anthropic/ppio/pa/claude-haiku-4-5-20251001",
      "fallback_models": ["OpenAI/azure_openai/o4-mini", "Xiaomi/mimo-v2.5"]
    },
    "writing": {
      "model": "Anthropic/ppio/pa/claude-sonnet-4-6",
      "fallback_models": ["Zhipu/zhipuai/glm-5", "Kimi/tongyi/kimi-k2.5", "Mify-Xiaomi/xiaomi/mimo-v2.5-pro"]
    },
    "unspecified-high": {
      "model": "Anthropic/ppio/pa/claude-sonnet-4-6",
      "fallback_models": ["Anthropic/ppio/pa/claude-opus-4-7", "OpenAI/azure_openai/gpt-5.5", "OpenAI/azure_openai/gpt-5.4", "Mify-Xiaomi/xiaomi/mimo-v2.5-pro", "Xiaomi/mimo-v2.5-pro"]
    },
    "unspecified-low": {
      "model": "Anthropic/ppio/pa/claude-haiku-4-5-20251001",
      "fallback_models": ["Mify-Xiaomi/xiaomi/mimo-v2.5", "Xiaomi/mimo-v2.5"]
    }
  },
  "background_task": {
    "defaultConcurrency": 3
  },
  "experimental": {
    "preemptive_compaction": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 3
      },
      "strategies": {
        "deduplication": { "enabled": true },
        "supersede_writes": { "enabled": true, "aggressive": false }
      }
    }
  }
}
