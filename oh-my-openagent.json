{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "_comment": "OpenCode SOTA Model Strategy - 2026 Q2 | 备份=百炼, 策略=智力与视觉最优",
  "categories": {
    "ultrabrain": {
      "model": "Anthropic/ppio/pa/claude-opus-4-6",
      "fallback_models": ["OpenAI/azure_openai/gpt-5.4-pro", "bailian/glm-5"]
    },
    "deep": {
      "model": "Anthropic/ppio/pa/claude-sonnet-4-6",
      "fallback_models": ["OpenAI/azure_openai/gpt-5.4", "bailian/qwen3.5-plus"]
    },
    "visual-engineering": {
      "model": "Google/gemini-3.1-pro-preview",
      "fallback_models": ["Anthropic/ppio/pa/claude-sonnet-4-6", "Google/gemini-3-flash-preview"]
    },
    "quick": {
      "model": "Anthropic/ppio/pa/claude-haiku-4-5-20251001",
      "fallback_models": ["bailian/qwen3.5-plus", "opencode/gpt-5-nano"]
    },
    "writing": {
      "model": "Anthropic/ppio/pa/claude-sonnet-4-6",
      "fallback_models": ["bailian/qwen3.5-plus", "opencode/gpt-5-chat"]
    },
    "unspecified-high": {
      "model": "OpenAI/azure_openai/gpt-5.4-pro",
      "fallback_models": ["Anthropic/ppio/pa/claude-sonnet-4-6"]
    },
    "unspecified-low": {
      "model": "Anthropic/ppio/pa/claude-haiku-4-5-20251001",
      "fallback_models": ["bailian/qwen3.5-plus"]
    }
  },
  "background_task": {
    "defaultConcurrency": 3
  },
  "experimental": {
    "preemptive_compaction": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 3
      },
      "strategies": {
        "deduplication": { "enabled": true },
        "supersede_writes": { "enabled": true, "aggressive": false }
      }
    }
  }
}
